APP_NAME=CoursePurchaseApp API
ENVIRONMENT=development
DATABASE_URL=postgresql+asyncpg://postgres:admin@localhost:5432/course_app
JWT_SECRET=change-this-to-a-long-random-production-secret
JWT_ISSUER=course-purchase-app
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=30
COOKIE_DOMAIN=
COOKIE_SECURE=false
CORS_ORIGINS=http://localhost:3000
CORS_ORIGIN_REGEX=^(https://.*\.vercel\.app|http://localhost:\d+)$
ADMIN_EMAIL=admin@coursestack.app
ADMIN_PASSWORD=change-this-admin-password
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
VERIFY_TOKEN_HOURS=24
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=CourseStack
SMTP_USE_TLS=true
